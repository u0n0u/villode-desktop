#!/usr/bin/env python3
import argparse
import fcntl
import html
import json
import os
import re
import signal
import subprocess
import sys
import tempfile
import time
from contextlib import contextmanager
from pathlib import Path
from urllib.parse import unquote, urlparse


APP_ID = "local.villode.desktop"
TITLE = "Villode Desktop"
DATA_DIR = Path.home() / ".local" / "share" / "villode-desktop"
DEFAULT_HTML = DATA_DIR / "home" / "index.html"
DEFAULT_WALLPAPER = DATA_DIR / "home" / "assets" / "villode-midnight-glass.png"
CONFIG_DIR = Path.home() / ".config" / "villode-desktop"
CONFIG_FILE = CONFIG_DIR / "config.json"
CAELESTIA_CONFIG_FILE = Path.home() / ".config" / "caelestia" / "shell.json"
CONFIG_LOCK_FILE = CONFIG_DIR / "config.lock"
PID_FILE = Path.home() / ".cache" / "villode-desktop.pid"
PID_LOCK_FILE = Path.home() / ".cache" / "villode-desktop.instance.lock"
OPERATION_LOCK_FILE = Path.home() / ".cache" / "villode-desktop.operation.lock"
HYPR_DIR = Path.home() / ".config" / "hypr"
HYPR_MAIN = HYPR_DIR / "hyprland.conf"
HYPR_INCLUDE_DIR = HYPR_DIR / "conf.d"
HYPR_INCLUDE = HYPR_INCLUDE_DIR / "villode-desktop.conf"
HYPR_SOURCE_LINE = "source = ~/.config/hypr/conf.d/villode-desktop.conf"
HYPR_DESKTOP_LINE = "$desktop = villode-desktop"
HYPR_AUTOSTART_LINE = "exec-once = villode-desktop --daemon"
HYPR_BIND_LINE = "bind = $mod SHIFT, D, exec, $desktop --toggle"
MODES = ("static", "video", "html")
FITS = ("cover", "contain", "stretch")
IMAGE_SUFFIXES = {".png", ".jpg", ".jpeg", ".webp", ".bmp", ".gif"}
VIDEO_SUFFIXES = {".mp4", ".webm", ".mkv", ".mov", ".m4v", ".avi"}
HTML_SUFFIXES = {".html", ".htm"}
DEFAULT_CONFIG = {
    "version": 2,
    "mode": "static",
    "source": str(DEFAULT_WALLPAPER),
    "sources": {
        "static": str(DEFAULT_WALLPAPER),
        "video": "",
        "html": str(DEFAULT_HTML),
    },
    "fit": "cover",
    "background": "#101522",
}
ACTION_COMMANDS = {
    "launcher": ["villode-launcher"],
    "terminal": ["alacritty"],
    "files": ["nautilus"],
    "browser": ["google-chrome-stable"],
    "settings": [str(Path(__file__).resolve()), "--configure"],
}


def read_pid():
    try:
        return int(PID_FILE.read_text().strip())
    except (FileNotFoundError, ValueError, OSError):
        return None


def process_alive(pid):
    if not pid:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True

    try:
        cmdline = Path(f"/proc/{pid}/cmdline").read_text(errors="ignore")
    except (FileNotFoundError, OSError):
        return False
    return "villode-desktop" in cmdline


@contextmanager
def exclusive_lock(path, blocking=True):
    path.parent.mkdir(parents=True, exist_ok=True)
    handle = path.open("a+")
    os.fchmod(handle.fileno(), 0o600)
    flags = fcntl.LOCK_EX | (0 if blocking else fcntl.LOCK_NB)
    try:
        fcntl.flock(handle.fileno(), flags)
    except BlockingIOError:
        handle.close()
        yield None
        return
    try:
        yield handle
    finally:
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
        handle.close()


def acquire_instance_lock():
    PID_LOCK_FILE.parent.mkdir(parents=True, exist_ok=True)
    handle = PID_LOCK_FILE.open("a+")
    os.fchmod(handle.fileno(), 0o600)
    try:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        handle.close()
        return None
    return handle


def release_instance_lock(handle):
    if handle is None:
        return
    fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
    handle.close()


def write_text_atomic(path, content):
    path.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temporary_name = tempfile.mkstemp(
        prefix=f".{path.name}.", suffix=".tmp", dir=path.parent
    )
    temporary = Path(temporary_name)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as stream:
            stream.write(content)
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def write_pid(pid):
    write_text_atomic(PID_FILE, f"{pid}\n")


def _stop_running():
    pid = read_pid()
    if not process_alive(pid):
        PID_FILE.unlink(missing_ok=True)
        return False

    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        PID_FILE.unlink(missing_ok=True)
        return False
    for _ in range(30):
        if not process_alive(pid):
            PID_FILE.unlink(missing_ok=True)
            return True
        time.sleep(0.05)

    try:
        os.kill(pid, signal.SIGKILL)
    except ProcessLookupError:
        pass
    PID_FILE.unlink(missing_ok=True)
    return True


def stop_running():
    with exclusive_lock(OPERATION_LOCK_FILE):
        return _stop_running()


def normalize_background(value):
    value = str(value or "").strip()
    if re.fullmatch(r"#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?", value):
        return value
    return DEFAULT_CONFIG["background"]


def load_config():
    config = {
        **DEFAULT_CONFIG,
        "sources": dict(DEFAULT_CONFIG["sources"]),
    }
    with exclusive_lock(CONFIG_LOCK_FILE):
        try:
            saved = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            saved = {}
    if isinstance(saved, dict):
        for key in ("mode", "source", "fit", "background"):
            if key in saved:
                config[key] = saved[key]
        saved_sources = saved.get("sources")
        if isinstance(saved_sources, dict):
            for mode in MODES:
                if isinstance(saved_sources.get(mode), str):
                    config["sources"][mode] = saved_sources[mode]
    if config["mode"] not in MODES:
        config["mode"] = DEFAULT_CONFIG["mode"]
    if config["fit"] not in FITS:
        config["fit"] = DEFAULT_CONFIG["fit"]
    legacy_source = (
        str(saved.get("source") or "") if isinstance(saved, dict) else ""
    )
    # Keep the long-standing top-level field authoritative for compatibility
    # with settings integrations which only update mode/source.
    if legacy_source:
        config["sources"][config["mode"]] = legacy_source
    config["sources"] = {
        mode: str(config["sources"].get(mode) or "") for mode in MODES
    }
    if not config["sources"]["static"]:
        config["sources"]["static"] = str(DEFAULT_WALLPAPER)
    config["source"] = config["sources"][config["mode"]]
    config["background"] = normalize_background(config.get("background"))
    config["version"] = 2
    return config


def save_config(config):
    mode = config["mode"]
    sources = dict(DEFAULT_CONFIG["sources"])
    supplied_sources = config.get("sources")
    if isinstance(supplied_sources, dict):
        for source_mode in MODES:
            if isinstance(supplied_sources.get(source_mode), str):
                sources[source_mode] = supplied_sources[source_mode]
    sources[mode] = str(config.get("source") or "")
    clean = {
        "version": 2,
        "mode": mode,
        "source": sources[mode],
        "sources": {source_mode: sources[source_mode] for source_mode in MODES},
        "fit": config["fit"],
        "background": normalize_background(config.get("background")),
    }
    CONFIG_DIR.mkdir(mode=0o700, parents=True, exist_ok=True)
    CONFIG_DIR.chmod(0o700)
    with exclusive_lock(CONFIG_LOCK_FILE):
        write_text_atomic(
            CONFIG_FILE,
            json.dumps(clean, ensure_ascii=False, indent=2) + "\n",
        )


def active_config_line(path, expected):
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except (FileNotFoundError, OSError):
        return False
    return any(line.strip() == expected for line in lines)


def autostart_enabled():
    return active_config_line(
        HYPR_INCLUDE, HYPR_AUTOSTART_LINE
    ) or active_config_line(HYPR_MAIN, HYPR_AUTOSTART_LINE)


def set_autostart(enabled):
    HYPR_INCLUDE_DIR.mkdir(parents=True, exist_ok=True)
    include_lines = [
        "# Villode Desktop",
        HYPR_DESKTOP_LINE,
        "",
    ]
    if enabled:
        include_lines.append(HYPR_AUTOSTART_LINE)
    include_lines.append(HYPR_BIND_LINE)
    write_text_atomic(HYPR_INCLUDE, "\n".join(include_lines) + "\n")

    HYPR_DIR.mkdir(parents=True, exist_ok=True)
    try:
        main_lines = HYPR_MAIN.read_text(encoding="utf-8").splitlines()
    except (FileNotFoundError, OSError):
        main_lines = []
    managed_direct_lines = {
        HYPR_DESKTOP_LINE,
        HYPR_AUTOSTART_LINE,
        HYPR_BIND_LINE,
    }
    clean_lines = [
        line
        for line in main_lines
        if line.strip() not in managed_direct_lines
    ]
    if not any(line.strip() == HYPR_SOURCE_LINE for line in clean_lines):
        if clean_lines and clean_lines[-1].strip():
            clean_lines.append("")
        clean_lines.extend(("# Villode Desktop", HYPR_SOURCE_LINE))
    write_text_atomic(HYPR_MAIN, "\n".join(clean_lines).rstrip() + "\n")

    try:
        subprocess.run(
            ["hyprctl", "reload"],
            check=False,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=2,
        )
    except (OSError, subprocess.TimeoutExpired):
        pass


def is_web_uri(source):
    return source.startswith(("http://", "https://"))


def local_source_path(source):
    if source.startswith("file://"):
        return Path(unquote(urlparse(source).path))
    if is_web_uri(source):
        return None
    return Path(source).expanduser().resolve()


def normalize_uri(source):
    if source.startswith(("http://", "https://", "file://")):
        return source
    return Path(source).expanduser().resolve().as_uri()


def is_trusted_home_uri(uri):
    if not isinstance(uri, str) or not uri.startswith("file://"):
        return False
    try:
        path = Path(unquote(urlparse(uri).path)).resolve()
        return path == DEFAULT_HTML.resolve()
    except (OSError, ValueError):
        return False


def validate_config(config):
    mode = config.get("mode")
    source = str(config.get("source") or "").strip()
    if mode not in MODES:
        return "不支持的桌面模式。"
    if not source:
        return "请选择或输入内容来源。"
    if mode == "static" and is_web_uri(source):
        return "静态图片模式请选择本地图片。"
    path = local_source_path(source)
    if path is not None and not path.is_file():
        return f"找不到文件：{path}"
    if path is not None:
        suffix = path.suffix.casefold()
        if mode == "static" and suffix not in IMAGE_SUFFIXES:
            return "静态图片模式只支持 PNG、JPG、WEBP、BMP 或 GIF 文件。"
        if mode == "video" and suffix not in VIDEO_SUFFIXES:
            return "循环视频模式只支持 MP4、WEBM、MKV、MOV、M4V 或 AVI 文件。"
        if mode == "html" and suffix not in HTML_SUFFIXES:
            return "本地 HTML 模式只支持 HTML 或 HTM 文件。"
    return None


def apply_static_wallpaper(source):
    path = local_source_path(str(source))
    if path is None:
        return False, "Caelestia 静态壁纸必须是本地文件。"
    try:
        result = subprocess.run(
            ["caelestia", "wallpaper", "-f", str(path)],
            check=False,
            stdin=subprocess.DEVNULL,
            capture_output=True,
            text=True,
            timeout=20,
        )
    except (OSError, subprocess.TimeoutExpired) as error:
        return False, f"无法调用 Caelestia 设置壁纸：{error}"
    if result.returncode != 0:
        message = (result.stderr or result.stdout).strip()
        return False, message or f"Caelestia 退出码：{result.returncode}"
    return True, ""


def _spawn_desktop(args=None):
    command = [str(Path(__file__).resolve()), "--run"]
    if args is not None:
        if getattr(args, "url", None):
            command.extend(("--url", args.url))
        if getattr(args, "escape_quits", False):
            command.append("--escape-quits")
    return subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
        close_fds=True,
    )


def wait_for_registration(process, timeout=2.0):
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        pid = read_pid()
        if process_alive(pid):
            return pid
        if process.poll() is not None:
            return None
        time.sleep(0.025)
    return read_pid() if process_alive(read_pid()) else None


def ensure_desktop_started(args=None):
    with exclusive_lock(OPERATION_LOCK_FILE):
        pid = read_pid()
        if process_alive(pid):
            return pid
        PID_FILE.unlink(missing_ok=True)
        process = _spawn_desktop(args)
        return wait_for_registration(process)


def restart_desktop(args=None, config=None):
    effective = config or load_config()
    if args is not None and getattr(args, "url", None):
        effective = {
            **effective,
            "mode": "html",
            "source": args.url,
        }
    with exclusive_lock(OPERATION_LOCK_FILE):
        _stop_running()
        if effective["mode"] == "static":
            return apply_static_wallpaper(effective["source"])
        process = _spawn_desktop(args)
        pid = wait_for_registration(process)
        if pid is None:
            return False, "Villode Desktop 进程未能启动。"
        return True, ""


def apply_saved_config(config, start_non_static):
    if config["mode"] == "static":
        success, message = apply_static_wallpaper(config["source"])
        if success:
            stop_running()
        return success, message
    if start_non_static:
        return restart_desktop(config=config)
    return True, ""


def toggle_desktop(args=None):
    config = load_config()
    with exclusive_lock(OPERATION_LOCK_FILE):
        if process_alive(read_pid()):
            _stop_running()
            return True, ""
        if config["mode"] == "static":
            return apply_static_wallpaper(config["source"])
        process = _spawn_desktop(args)
        if wait_for_registration(process) is None:
            return False, "Villode Desktop 进程未能启动。"
        return True, ""


def set_if_supported(obj, name, value):
    try:
        obj.set_property(name, value)
    except Exception:
        pass


def launch_command(command):
    subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def build_video_document(config):
    source = html.escape(normalize_uri(config["source"]), quote=True)
    fit = "fill" if config["fit"] == "stretch" else config["fit"]
    background = normalize_background(config.get("background"))
    return f"""<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    html, body {{ width: 100%; height: 100%; margin: 0; overflow: hidden; background: {background}; }}
    video {{ width: 100%; height: 100%; display: block; object-fit: {fit}; background: {background}; }}
    #error {{ display: none; position: fixed; inset: 0; place-items: center; color: #dce7f8;
      background: {background}; font: 16px system-ui, sans-serif; }}
  </style>
</head>
<body>
  <video id="wallpaper" src="{source}" autoplay muted loop playsinline preload="auto"
    disablepictureinpicture disableremoteplayback></video>
  <div id="error">无法播放当前视频，请打开 Villode Desktop 设置更换文件。</div>
  <script>
    const video = document.getElementById("wallpaper");
    const error = document.getElementById("error");
    video.muted = true;
    video.play().catch(() => {{}});
    video.addEventListener("error", () => {{ error.style.display = "grid"; }});
    document.addEventListener("visibilitychange", () => {{
      if (document.hidden) video.pause();
      else video.play().catch(() => {{}});
    }});
  </script>
</body>
</html>"""


def run_configurator():
    import gi

    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk

    config = load_config()
    dialog = Gtk.Dialog(title="Villode Desktop 设置")
    dialog.set_default_size(680, 340)
    dialog.set_resizable(False)
    dialog.add_button("取消", Gtk.ResponseType.CANCEL)
    dialog.add_button("保存并应用", Gtk.ResponseType.APPLY)
    dialog.set_default_response(Gtk.ResponseType.APPLY)

    content = dialog.get_content_area()
    content.set_border_width(20)
    content.set_spacing(14)

    title = Gtk.Label()
    title.set_markup("<span size='x-large' weight='bold'>桌面背景</span>")
    title.set_xalign(0)
    content.pack_start(title, False, False, 0)

    subtitle = Gtk.Label(
        label="静态图片交给 Caelestia 统一显示；视频使用硬件加速的 WebKit/GStreamer；HTML 可选择本地文件或输入网址。"
    )
    subtitle.set_xalign(0)
    subtitle.set_line_wrap(True)
    content.pack_start(subtitle, False, False, 0)

    grid = Gtk.Grid(column_spacing=12, row_spacing=12)
    content.pack_start(grid, True, True, 0)

    def field_label(text, row):
        label = Gtk.Label(label=text)
        label.set_xalign(1)
        grid.attach(label, 0, row, 1, 1)

    field_label("类型", 0)
    mode_combo = Gtk.ComboBoxText()
    mode_combo.append("static", "静态图片")
    mode_combo.append("video", "循环视频")
    mode_combo.append("html", "自定义 HTML / 网址")
    mode_combo.set_active_id(config["mode"])
    grid.attach(mode_combo, 1, 0, 2, 1)

    field_label("来源", 1)
    source_entry = Gtk.Entry()
    source_entry.set_hexpand(True)
    source_entry.set_text(config["source"])
    grid.attach(source_entry, 1, 1, 1, 1)
    browse_button = Gtk.Button(label="浏览…")
    grid.attach(browse_button, 2, 1, 1, 1)

    field_label("填充方式", 2)
    fit_combo = Gtk.ComboBoxText()
    fit_combo.append("cover", "覆盖屏幕（可能裁剪）")
    fit_combo.append("contain", "完整显示（可能留边）")
    fit_combo.append("stretch", "拉伸填满")
    fit_combo.set_active_id(config["fit"])
    grid.attach(fit_combo, 1, 2, 2, 1)

    field_label("背景色", 3)
    background_entry = Gtk.Entry()
    background_entry.set_text(config["background"])
    background_entry.set_max_length(9)
    grid.attach(background_entry, 1, 3, 2, 1)

    field_label("自动启动", 4)
    autostart_check = Gtk.CheckButton(label="登录 Hyprland 后自动运行")
    autostart_check.set_active(autostart_enabled())
    grid.attach(autostart_check, 1, 4, 2, 1)

    hint = Gtk.Label()
    hint.set_xalign(0)
    hint.set_line_wrap(True)
    grid.attach(hint, 1, 5, 2, 1)

    last_mode = mode_combo.get_active_id()
    mode_sources = dict(config["sources"])
    mode_sources[last_mode] = source_entry.get_text()

    def update_mode_ui(*_args):
        nonlocal last_mode
        mode = mode_combo.get_active_id()
        if mode != last_mode:
            mode_sources[last_mode] = source_entry.get_text()
            source_entry.set_text(mode_sources.get(mode, ""))
            last_mode = mode
        fit_combo.set_sensitive(mode == "video")
        background_entry.set_sensitive(mode == "video")
        if mode == "static":
            source_entry.set_placeholder_text("选择 PNG、JPG、WEBP 等图片")
            hint.set_text("静态模式由 Caelestia 显示，不会额外创建桌面图层。")
        elif mode == "video":
            source_entry.set_placeholder_text("选择 MP4、WEBM、MKV 等视频")
            hint.set_text("视频会自动静音并循环播放，推荐 1080p / 24 FPS / H.264。")
        else:
            source_entry.set_placeholder_text("选择 .html 文件，或输入 https:// 网址")
            hint.set_text("本地 HTML 可以自己编写；它仍会运行在独立 WebKit 进程中。")

    def browse_source(_button):
        mode = mode_combo.get_active_id()
        chooser = Gtk.FileChooserDialog(
            title="选择桌面内容",
            parent=dialog,
            action=Gtk.FileChooserAction.OPEN,
        )
        chooser.add_buttons(
            "取消",
            Gtk.ResponseType.CANCEL,
            "选择",
            Gtk.ResponseType.OK,
        )
        media_filter = Gtk.FileFilter()
        if mode == "static":
            media_filter.set_name("图片")
            patterns = ("*.png", "*.jpg", "*.jpeg", "*.webp", "*.bmp", "*.gif")
        elif mode == "video":
            media_filter.set_name("视频")
            patterns = ("*.mp4", "*.webm", "*.mkv", "*.mov", "*.m4v", "*.avi")
        else:
            media_filter.set_name("HTML")
            patterns = ("*.html", "*.htm")
        for pattern in patterns:
            media_filter.add_pattern(pattern)
            media_filter.add_pattern(pattern.upper())
        chooser.add_filter(media_filter)
        current = local_source_path(source_entry.get_text().strip())
        if current is not None:
            if current.is_file():
                chooser.set_filename(str(current))
            elif current.parent.is_dir():
                chooser.set_current_folder(str(current.parent))
        if chooser.run() == Gtk.ResponseType.OK:
            source_entry.set_text(chooser.get_filename())
        chooser.destroy()

    mode_combo.connect("changed", update_mode_ui)
    browse_button.connect("clicked", browse_source)
    update_mode_ui()
    dialog.show_all()

    selected = None
    while True:
        response = dialog.run()
        if response != Gtk.ResponseType.APPLY:
            break
        candidate = {
            "version": 2,
            "mode": mode_combo.get_active_id(),
            "source": source_entry.get_text().strip(),
            "sources": {
                **mode_sources,
                mode_combo.get_active_id(): source_entry.get_text().strip(),
            },
            "fit": fit_combo.get_active_id() or "cover",
            "background": normalize_background(background_entry.get_text()),
        }
        error = validate_config(candidate)
        if error:
            message = Gtk.MessageDialog(
                transient_for=dialog,
                modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.CLOSE,
                text="无法保存设置",
            )
            message.format_secondary_text(error)
            message.run()
            message.destroy()
            continue
        selected = candidate
        break

    dialog.destroy()
    if selected is not None:
        save_config(selected)
        set_autostart(autostart_check.get_active())
        success, message = apply_saved_config(selected, True)
        if not success:
            print(f"应用桌面设置失败：{message}", file=sys.stderr)
            return 1
    return 0


def run_desktop(args):
    config = load_config()
    if args.url:
        config.update({"mode": "html", "source": args.url})
    if config["mode"] == "static":
        success, message = apply_static_wallpaper(config["source"])
        if not success:
            print(message, file=sys.stderr)
            return 1
        return 0

    instance_lock = acquire_instance_lock()
    if instance_lock is None:
        return 0

    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    gi.require_version("GtkLayerShell", "0.1")
    gi.require_version("WebKit2", "4.1")

    from gi.repository import Gdk, Gio, GLib, Gtk, GtkLayerShell, WebKit2

    write_pid(os.getpid())

    def error_widget(message):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)
        label = Gtk.Label()
        label.set_markup(
            "<span size='x-large' weight='bold'>Villode Desktop</span>\n\n"
            + html.escape(message)
            + "\n\n运行 villode-desktop --configure 更换内容。"
        )
        label.set_justify(Gtk.Justification.CENTER)
        box.pack_start(label, False, False, 0)
        return box

    class DesktopApp(Gtk.Application):
        def __init__(self):
            super().__init__(application_id=APP_ID, flags=Gio.ApplicationFlags.FLAGS_NONE)
            self.window = None
            self.webview = None
            self.content = None

        def make_webview(self, local_file_access=False, trusted_actions=False):
            manager = WebKit2.UserContentManager()
            try:
                shell_config = json.loads(CAELESTIA_CONFIG_FILE.read_text())
                weather_location = str(
                    shell_config.get("services", {}).get("weatherLocation", "")
                ).strip()
            except (FileNotFoundError, OSError, ValueError, TypeError):
                weather_location = ""
            manager.add_script(
                WebKit2.UserScript.new(
                    "window.__VILLODE_WEATHER_LOCATION__ = "
                    + json.dumps(weather_location, ensure_ascii=False)
                    + ";",
                    WebKit2.UserContentInjectedFrames.TOP_FRAME,
                    WebKit2.UserScriptInjectionTime.START,
                    None,
                    None,
                )
            )
            webview = WebKit2.WebView.new_with_user_content_manager(manager)
            self.trusted_actions = bool(trusted_actions)
            self.remote_html = config["mode"] == "html" and is_web_uri(config["source"])
            settings = webview.get_settings()
            set_if_supported(settings, "enable-developer-extras", False)
            set_if_supported(settings, "enable-smooth-scrolling", True)
            set_if_supported(
                settings, "allow-file-access-from-file-urls", bool(local_file_access)
            )
            set_if_supported(settings, "allow-universal-access-from-file-urls", False)
            set_if_supported(settings, "javascript-can-access-clipboard", False)
            set_if_supported(settings, "allow-modal-dialogs", False)
            set_if_supported(settings, "media-playback-requires-user-gesture", False)
            try:
                settings.set_hardware_acceleration_policy(WebKit2.HardwareAccelerationPolicy.ALWAYS)
            except Exception:
                pass
            webview.connect("decide-policy", self.on_decide_policy)
            webview.connect("permission-request", self.on_permission_request)
            webview.connect("create", lambda *_args: None)
            webview.connect("context-menu", lambda *_args: True)
            return webview

        def source_is_trusted_home(self):
            if config["mode"] != "html" or is_web_uri(config["source"]):
                return False
            path = local_source_path(config["source"])
            if path is None:
                return False
            try:
                return path.resolve() == DEFAULT_HTML.resolve()
            except OSError:
                return False

        def on_permission_request(self, _webview, request):
            request.deny()
            return True

        def build_content(self):
            error = validate_config(config)
            if error:
                return error_widget(error)
            try:
                if config["mode"] == "video":
                    webview = self.make_webview(local_file_access=True)
                    self.webview = webview
                    source_path = local_source_path(config["source"])
                    base_uri = None
                    if source_path is not None:
                        base_uri = source_path.parent.as_uri() + "/"
                    webview.load_html(build_video_document(config), base_uri)
                else:
                    local_html = not is_web_uri(config["source"])
                    webview = self.make_webview(
                        local_file_access=local_html,
                        trusted_actions=self.source_is_trusted_home(),
                    )
                    self.webview = webview
                    webview.load_uri(normalize_uri(config["source"]))
                return webview
            except Exception as exc:
                return error_widget(str(exc))

        def do_activate(self):
            if self.window:
                self.window.present()
                return

            window = Gtk.ApplicationWindow(application=self)
            window.set_title(f"{TITLE} — {config['mode']}")
            window.set_name("villode-desktop-window")
            window.set_decorated(False)
            window.set_resizable(True)
            window.set_skip_taskbar_hint(True)
            window.set_skip_pager_hint(True)
            window.set_accept_focus(True)
            window.set_keep_below(True)
            window.set_type_hint(Gdk.WindowTypeHint.DESKTOP)

            GtkLayerShell.init_for_window(window)
            GtkLayerShell.set_namespace(window, "villode-desktop")
            GtkLayerShell.set_layer(window, GtkLayerShell.Layer.BACKGROUND)
            GtkLayerShell.set_keyboard_mode(window, GtkLayerShell.KeyboardMode.ON_DEMAND)
            for edge in (
                GtkLayerShell.Edge.TOP,
                GtkLayerShell.Edge.RIGHT,
                GtkLayerShell.Edge.BOTTOM,
                GtkLayerShell.Edge.LEFT,
            ):
                GtkLayerShell.set_anchor(window, edge, True)
                GtkLayerShell.set_margin(window, edge, 0)
            GtkLayerShell.set_exclusive_zone(window, -1)

            self.content = self.build_content()
            window.add(self.content)
            window.connect("key-press-event", self.on_key_press)
            window.connect("destroy", lambda *_: self.quit())
            window.show_all()
            self.window = window

        def on_key_press(self, _window, event):
            key = Gdk.keyval_name(event.keyval) or ""
            ctrl = bool(event.state & Gdk.ModifierType.CONTROL_MASK)
            if key == "F5" or (ctrl and key.lower() == "r"):
                if self.webview:
                    self.webview.reload()
                elif self.content:
                    self.content.queue_draw()
                return True
            if ctrl and key == ",":
                launch_command(ACTION_COMMANDS["settings"])
                return True
            if (ctrl and key.lower() == "q") or (args.escape_quits and key == "Escape"):
                self.quit()
                return True
            return False

        def on_decide_policy(self, _webview, decision, decision_type):
            if decision_type == WebKit2.PolicyDecisionType.NEW_WINDOW_ACTION:
                decision.ignore()
                return True
            if decision_type != WebKit2.PolicyDecisionType.NAVIGATION_ACTION:
                return False
            action = decision.get_navigation_action()
            request = action.get_request() if action else None
            target_uri = request.get_uri() if request else ""
            parsed = urlparse(target_uri)
            scheme = parsed.scheme.casefold()
            if self.remote_html and scheme not in {"http", "https", "about"}:
                decision.ignore()
                return True
            if not target_uri.startswith("villode-action://"):
                return False

            decision.ignore()
            user_gesture = bool(action and action.is_user_gesture())
            if not (
                self.trusted_actions
                and user_gesture
                and is_trusted_home_uri(_webview.get_uri())
            ):
                return True
            name = urlparse(target_uri).netloc or urlparse(target_uri).path.lstrip("/")
            if name == "reload":
                self.webview.reload()
            elif name == "quit":
                self.quit()
            elif name in ACTION_COMMANDS:
                launch_command(ACTION_COMMANDS[name])
            return True

    app = DesktopApp()

    def request_quit(*_args):
        app.quit()
        return False

    GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGTERM, request_quit)
    GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGINT, request_quit)

    try:
        return app.run([])
    finally:
        if read_pid() == os.getpid():
            PID_FILE.unlink(missing_ok=True)
        release_instance_lock(instance_lock)


def main():
    parser = argparse.ArgumentParser(description="Villode Hyprland desktop background manager")
    parser.add_argument("--run", action="store_true", help="run the desktop layer in this process")
    parser.add_argument("--daemon", action="store_true", help="start the configured desktop layer")
    parser.add_argument("--toggle", action="store_true", help="toggle the desktop layer")
    parser.add_argument("--reload", action="store_true", help="restart and reload the desktop layer")
    parser.add_argument("--quit", action="store_true", help="stop the desktop layer")
    parser.add_argument("--configure", "--settings", action="store_true", help="open graphical settings")
    parser.add_argument("--status", action="store_true", help="show the saved configuration and process state")
    autostart_group = parser.add_mutually_exclusive_group()
    autostart_group.add_argument(
        "--enable-autostart",
        action="store_true",
        help="start Villode Desktop automatically after Hyprland login",
    )
    autostart_group.add_argument(
        "--disable-autostart",
        action="store_true",
        help="disable automatic startup after Hyprland login",
    )
    autostart_group.add_argument(
        "--autostart-status",
        action="store_true",
        help="show whether Hyprland autostart is enabled",
    )
    parser.add_argument("--url", help="compatibility override: render this local HTML file or URL")
    source_group = parser.add_mutually_exclusive_group()
    source_group.add_argument("--set-static", metavar="PATH", help="select a static image")
    source_group.add_argument("--set-video", metavar="PATH", help="select a looping video")
    source_group.add_argument("--set-html", metavar="PATH_OR_URL", help="select custom HTML or a URL")
    parser.add_argument("--fit", choices=FITS, help="image/video fit mode")
    parser.add_argument("--background", metavar="#RRGGBB", help="background color")
    parser.add_argument("--escape-quits", action="store_true", help="let Escape close the desktop layer")
    args = parser.parse_args()

    if args.configure:
        return run_configurator()
    if args.enable_autostart:
        set_autostart(True)
        config = load_config()
        if config["mode"] == "static":
            success, message = apply_saved_config(config, False)
        else:
            success = ensure_desktop_started(args) is not None
            message = "" if success else "Villode Desktop 进程未能启动。"
        if not success:
            print(message, file=sys.stderr)
            return 1
        print("已启用 Villode Desktop 登录后自动运行。")
        return 0
    if args.disable_autostart:
        set_autostart(False)
        print("已关闭 Villode Desktop 登录后自动运行。")
        return 0
    if args.autostart_status:
        print("enabled" if autostart_enabled() else "disabled")
        return 0
    if args.status:
        payload = load_config()
        payload["running"] = process_alive(read_pid())
        payload["pid"] = read_pid() if payload["running"] else None
        payload["autostart"] = autostart_enabled()
        print(json.dumps(payload, ensure_ascii=False, indent=2))
        return 0

    selected = None
    if args.set_static:
        selected = ("static", args.set_static)
    elif args.set_video:
        selected = ("video", args.set_video)
    elif args.set_html:
        selected = ("html", args.set_html)
    if selected or args.fit or args.background:
        config = load_config()
        if selected:
            config["mode"], config["source"] = selected
        if args.fit:
            config["fit"] = args.fit
        if args.background:
            config["background"] = normalize_background(args.background)
        error = validate_config(config)
        if error:
            print(error, file=sys.stderr)
            return 2
        was_running = process_alive(read_pid())
        save_config(config)
        success, message = apply_saved_config(
            config, was_running or selected is not None
        )
        if not success:
            print(f"应用桌面设置失败：{message}", file=sys.stderr)
            return 1
        print(f"已设置 {config['mode']} 桌面：{config['source']}")
        return 0

    if args.quit:
        stop_running()
        return 0
    if args.reload:
        success, message = restart_desktop(args)
        if not success:
            print(message, file=sys.stderr)
            return 1
        return 0
    if args.toggle:
        success, message = toggle_desktop(args)
        if not success:
            print(message, file=sys.stderr)
            return 1
        return 0
    if args.daemon:
        config = load_config()
        if config["mode"] == "static":
            success, message = apply_saved_config(config, False)
        else:
            success = ensure_desktop_started(args) is not None
            message = "" if success else "Villode Desktop 进程未能启动。"
        if not success:
            print(message, file=sys.stderr)
            return 1
        return 0
    if args.run:
        return run_desktop(args)

    parser.print_help()
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
