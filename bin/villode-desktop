def read_pid():
    try:
        return int(PID_FILE.read_text().strip())
    except (FileNotFoundError, ValueError, OSError):
        return None


def process_alive(pid):
    if not pid:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True

    try:
        cmdline = Path(f"/proc/{pid}/cmdline").read_text(errors="ignore")
    except (FileNotFoundError, OSError):
        return False
    return "villode-desktop" in cmdline


@contextmanager
def exclusive_lock(path, blocking=True):
    path.parent.mkdir(parents=True, exist_ok=True)
    handle = path.open("a+")
    os.fchmod(handle.fileno(), 0o600)
    flags = fcntl.LOCK_EX | (0 if blocking else fcntl.LOCK_NB)
    try:
        fcntl.flock(handle.fileno(), flags)
    except BlockingIOError:
        handle.close()
        yield None
        return
    try:
        yield handle
    finally:
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
        handle.close()


def acquire_instance_lock():
    PID_LOCK_FILE.parent.mkdir(parents=True, exist_ok=True)
    handle = PID_LOCK_FILE.open("a+")
    os.fchmod(handle.fileno(), 0o600)
    try:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        handle.close()
        return None
    return handle


def release_instance_lock(handle):
    if handle is None:
        return
    fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
    handle.close()


def write_text_atomic(path, content):
    path.parent.mkdir(parents=True, exist_ok=True)
    descriptor, temporary_name = tempfile.mkstemp(
        prefix=f".{path.name}.", suffix=".tmp", dir=path.parent
    )
    temporary = Path(temporary_name)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as stream:
            stream.write(content)
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def write_pid(pid):
    write_text_atomic(PID_FILE, f"{pid}\n")


def _stop_running():
    pid = read_pid()
    if not process_alive(pid):
        PID_FILE.unlink(missing_ok=True)
        return False

    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        PID_FILE.unlink(missing_ok=True)
        return False
    for _ in range(30):
        if not process_alive(pid):
            PID_FILE.unlink(missing_ok=True)
            return True
        time.sleep(0.05)

    try:
        os.kill(pid, signal.SIGKILL)
    except ProcessLookupError:
        pass
    PID_FILE.unlink(missing_ok=True)
    return True


def stop_running():
    with exclusive_lock(OPERATION_LOCK_FILE):
        return _stop_running()


def normalize_background(value):
    value = str(value or "").strip()
    if re.fullmatch(r"#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?", value):
        return value
    return DEFAULT_CONFIG["background"]




def clamp_playback_scale(value):
    try:
        scale = float(value)
    except (TypeError, ValueError):
        scale = DEFAULT_CONFIG["playback_scale"]
    return max(0.5, min(1.0, scale))


def clamp_cover_threshold(value):
    try:
        t = float(value)
    except (TypeError, ValueError):
        t = DEFAULT_CONFIG["pause_cover_threshold"]
    return max(0.15, min(0.95, t))


def clamp_max_video_height(value):
    try:
        h = int(value)
    except (TypeError, ValueError):
        h = 0
    if h <= 0:
        return 0
    return max(360, min(2160, h))


def on_battery():
    """True when a BAT* supply reports Discharging (AC unplugged)."""
    try:
        base = Path("/sys/class/power_supply")
        if not base.is_dir():
            return False
        for entry in base.iterdir():
            name = entry.name
            if not name.startswith("BAT"):
                continue
            status = (entry / "status").read_text(encoding="utf-8").strip()
            if status == "Discharging":
                return True
        return False
    except OSError:
        return False


def effective_power_params(config=None):
    """Scale / cover threshold after optional battery boost."""
    cfg = config or {}
    scale = clamp_playback_scale(cfg.get("playback_scale", DEFAULT_CONFIG["playback_scale"]))
    thr = clamp_cover_threshold(
        cfg.get("pause_cover_threshold", DEFAULT_CONFIG["pause_cover_threshold"])
    )
    batt = False
    if as_bool(cfg.get("battery_power_boost", True), True) and on_battery():
        batt = True
        scale = min(scale, 0.65)
        thr = min(thr, 0.25)
    return {
        "playback_scale": scale,
        "pause_cover_threshold": thr,
        "on_battery": batt,
        "max_video_height": clamp_max_video_height(cfg.get("max_video_height", 0)),
    }


def as_bool(value, default=True):
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return bool(value)
    if isinstance(value, str):
        text = value.strip().casefold()
        if text in {"1", "true", "yes", "on"}:
            return True
        if text in {"0", "false", "no", "off"}:
            return False
    return default


def hyprctl_json(command, timeout=0.8):
    """Run hyprctl -j <command> and parse JSON. Returns None on failure."""
    try:
        completed = subprocess.run(
            ["hyprctl", "-j", command],
            check=False,
            capture_output=True,
            text=True,
            timeout=timeout,
            stdin=subprocess.DEVNULL,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if completed.returncode != 0 or not (completed.stdout or "").strip():
        return None
    try:
        return json.loads(completed.stdout)
    except json.JSONDecodeError:
        return None


def hyprland_session_locked():
    """Best-effort lock detection (hyprlock / session lock)."""
    # hyprctl clients sometimes includes lock surface; also check processes
    try:
        for entry in Path("/proc").iterdir():
            if not entry.name.isdigit():
                continue
            try:
                cmd = (entry / "cmdline").read_text(errors="ignore")
            except (FileNotFoundError, OSError, PermissionError):
                continue
            if "hyprlock" in cmd or "swaylock" in cmd or "waylock" in cmd:
                return True
    except OSError:
        pass
    return False


def hyprland_should_pause_media(config=None):
    """
    Return (pause: bool, reason: str).

    Pause when: DPMS off, session lock, or a non-desktop client that truly
    occludes the wallpaper on a monitor's *active* workspace.

    Important: Hyprland keeps windows on other workspaces as mapped; we must
    not pause because of fullscreen apps on a hidden workspace (that made
    video wallpapers freeze while the desktop was fully visible).
    """
    cfg = config or {}
    if not as_bool(cfg.get("power_save", True), True):
        return False, "power_save_off"

    if as_bool(cfg.get("pause_when_locked", True), True) and hyprland_session_locked():
        return True, "locked"

    monitors = hyprctl_json("monitors")
    clients = hyprctl_json("clients")
    if not isinstance(monitors, list) or not monitors:
        return False, "no_hypr"

    if as_bool(cfg.get("pause_when_dpms_off", True), True):
        # If every monitor is DPMS-off, pause. If any focused is off, pause.
        any_on = False
        focused_off = False
        for mon in monitors:
            if not isinstance(mon, dict):
                continue
            on = bool(mon.get("dpmsStatus", True))
            if on:
                any_on = True
            if mon.get("focused") and not on:
                focused_off = True
        if focused_off or not any_on:
            return True, "dpms_off"

    if not as_bool(cfg.get("pause_when_occluded", True), True):
        return False, "ok"

    if not isinstance(clients, list):
        return False, "ok"

    # Per-monitor active workspace id (wallpaper is only covered there).
    mon_by_id = {}
    active_ws_by_mon = {}
    for mon in monitors:
        if not isinstance(mon, dict) or "id" not in mon:
            continue
        mon_by_id[mon["id"]] = mon
        aw = mon.get("activeWorkspace") or {}
        try:
            active_ws_by_mon[mon["id"]] = int(aw.get("id"))
        except (TypeError, ValueError, AttributeError):
            active_ws_by_mon[mon["id"]] = None

    def is_desktop_client(client):
        cls = str(client.get("class") or "")
        initial = str(client.get("initialClass") or "")
        title = str(client.get("title") or "")
        for token in (cls, initial, title):
            low = token.casefold()
            if "villode-desktop" in low or "local.villode.desktop" in low:
                return True
        return False

    def client_workspace_id(client):
        ws = client.get("workspace") or {}
        if isinstance(ws, dict):
            try:
                return int(ws.get("id"))
            except (TypeError, ValueError):
                return None
        try:
            return int(ws)
        except (TypeError, ValueError):
            return None

    def parse_fs(value):
        # Hyprland: 0 none, 1 maximize, 2 fullscreen (sometimes bool).
        try:
            return int(value or 0)
        except (TypeError, ValueError):
            return 1 if value else 0

    def usable_area(mon):
        try:
            mw = float(mon.get("width") or 0)
            mh = float(mon.get("height") or 0)
        except (TypeError, ValueError):
            return 0.0, 0.0
        reserved = mon.get("reserved") or [0, 0, 0, 0]
        # reserved: [top, right, bottom, left] in recent hyprctl
        try:
            top, right, bottom, left = [float(x) for x in reserved[:4]]
        except (TypeError, ValueError):
            top = right = bottom = left = 0.0
        uw = max(0.0, mw - left - right)
        uh = max(0.0, mh - top - bottom)
        return uw, uh

    for client in clients:
        if not isinstance(client, dict):
            continue
        if not client.get("mapped", True) or client.get("hidden"):
            continue
        if is_desktop_client(client):
            continue

        mon_id = client.get("monitor")
        mon = mon_by_id.get(mon_id)
        if not mon:
            continue

        # Only windows on this monitor's *visible* workspace cover wallpaper.
        active_ws = active_ws_by_mon.get(mon_id)
        c_ws = client_workspace_id(client)
        if active_ws is not None and c_ws is not None and c_ws != active_ws:
            continue

        fs_i = parse_fs(client.get("fullscreen", 0))
        fsc_i = parse_fs(client.get("fullscreenClient", 0))
        # True exclusive fullscreen only (not mere maximize=1).
        if fs_i >= 2 or fsc_i >= 2:
            return True, "fullscreen"

        size = client.get("size") or [0, 0]
        if not isinstance(size, (list, tuple)) or len(size) < 2:
            continue
        try:
            w, h = float(size[0]), float(size[1])
        except (TypeError, ValueError):
            continue
        uw, uh = usable_area(mon)
        if uw <= 0 or uh <= 0:
            continue
        area = w * h
        usable = uw * uh
        # True exclusive fullscreen already handled. Maximize always pauses.
        if fs_i >= 1 or fsc_i >= 1:
            if area >= 0.55 * usable:
                return True, "maximized"
        # Any large enough window on the visible workspace hides wallpaper —
        # keep decoding only when most of the desktop is still visible.
        thr = clamp_cover_threshold(
            cfg.get("pause_cover_threshold", DEFAULT_CONFIG["pause_cover_threshold"])
        )
        if as_bool(cfg.get("battery_power_boost", True), True) and on_battery():
            thr = min(thr, 0.25)
        if area >= thr * usable:
            return True, "covered"

    return False, "ok"


def power_user_script():
    """Injected into every wallpaper WebView: pause videos/CSS when told."""
    return r"""
(function () {
  if (window.__VILLODE_POWER__) return;
  window.__VILLODE_POWER__ = true;
  var paused = false;
  var saved = [];

  function collectVideos() {
    return Array.prototype.slice.call(document.querySelectorAll("video"));
  }

  function freezeCss() {
    try {
      if (!document.documentElement.dataset.villodeAnimSaved) {
        document.documentElement.dataset.villodeAnimSaved = "1";
        var s = document.createElement("style");
        s.id = "villode-power-css";
        s.textContent =
          "html.villode-power-paused, html.villode-power-paused * {" +
          "  animation-play-state: paused !important;" +
          "  transition: none !important;" +
          "}";
        (document.head || document.documentElement).appendChild(s);
      }
      document.documentElement.classList.add("villode-power-paused");
    } catch (e) {}
  }

  function thawCss() {
    try {
      document.documentElement.classList.remove("villode-power-paused");
    } catch (e) {}
  }

  window.__villodeSetPaused = function (next) {
    next = !!next;
    if (next === paused) return;
    paused = next;
    if (paused) {
      saved = collectVideos().map(function (v) {
        return { el: v, wasPlaying: !v.paused && !v.ended };
      });
      saved.forEach(function (item) {
        try { item.el.pause(); } catch (e) {}
      });
      freezeCss();
    } else {
      thawCss();
      saved.forEach(function (item) {
        if (item.wasPlaying) {
          try { item.el.play().catch(function () {}); } catch (e) {}
        }
      });
      // Also resume autoplay/loop videos that were added later
      collectVideos().forEach(function (v) {
        if (v.hasAttribute("autoplay") || v.loop) {
          try { v.play().catch(function () {}); } catch (e) {}
        }
      });
      saved = [];
    }
  };

  // Background layer-shell WebViews often report document.hidden=true even
  // when the wallpaper is on-screen. Only pause from host poll / pagehide.
  document.addEventListener("pagehide", function () {
    window.__villodeSetPaused(true);
  });
  document.addEventListener("pageshow", function () {
    if (!window.__villodeHostPaused) window.__villodeSetPaused(false);
  });
})();
"""


def load_config():
    config = {
        **DEFAULT_CONFIG,
        "sources": dict(DEFAULT_CONFIG["sources"]),
    }
    with exclusive_lock(CONFIG_LOCK_FILE):
        try:
            saved = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            saved = {}
    if isinstance(saved, dict):
        for key in ("mode", "source", "fit", "background"):
            if key in saved:
                config[key] = saved[key]
        for key in (
            "power_save",
            "pause_when_occluded",
            "pause_when_locked",
            "pause_when_dpms_off",
            "battery_power_boost",
            "pause_cover_threshold",
            "playback_scale",
            "max_video_height",
            "video_backend",
        ):
            if key in saved:
                config[key] = saved[key]
        saved_sources = saved.get("sources")
        if isinstance(saved_sources, dict):
            for mode in MODES:
                if isinstance(saved_sources.get(mode), str):
                    config["sources"][mode] = saved_sources[mode]
    if config["mode"] not in MODES:
        config["mode"] = DEFAULT_CONFIG["mode"]
    if config["fit"] not in FITS:
        config["fit"] = DEFAULT_CONFIG["fit"]
    config["power_save"] = as_bool(config.get("power_save", True), True)
    config["pause_when_occluded"] = as_bool(config.get("pause_when_occluded", True), True)
    config["pause_when_locked"] = as_bool(config.get("pause_when_locked", True), True)
    config["pause_when_dpms_off"] = as_bool(config.get("pause_when_dpms_off", True), True)
    config["battery_power_boost"] = as_bool(config.get("battery_power_boost", True), True)
    config["pause_cover_threshold"] = clamp_cover_threshold(
        config.get("pause_cover_threshold", DEFAULT_CONFIG["pause_cover_threshold"])
    )
    config["playback_scale"] = clamp_playback_scale(
        config.get("playback_scale", DEFAULT_CONFIG["playback_scale"])
    )
    config["max_video_height"] = clamp_max_video_height(config.get("max_video_height", 0))
    backend = str(config.get("video_backend", "mpv") or "mpv").strip().lower()
    config["video_backend"] = backend if backend in {"mpv", "webkit"} else "mpv"
    legacy_source = (
        str(saved.get("source") or "") if isinstance(saved, dict) else ""
    )
    # Keep the long-standing top-level field authoritative for compatibility
    # with settings integrations which only update mode/source.
    if legacy_source:
        config["sources"][config["mode"]] = legacy_source
    config["sources"] = {
        mode: str(config["sources"].get(mode) or "") for mode in MODES
    }
    if not config["sources"]["static"]:
        config["sources"]["static"] = str(DEFAULT_WALLPAPER)
    config["source"] = config["sources"][config["mode"]]
    config["background"] = normalize_background(config.get("background"))
    config["version"] = 2
    return config


def save_config(config):
    mode = config["mode"]
    sources = dict(DEFAULT_CONFIG["sources"])
    supplied_sources = config.get("sources")
    if isinstance(supplied_sources, dict):
        for source_mode in MODES:
            if isinstance(supplied_sources.get(source_mode), str):
                sources[source_mode] = supplied_sources[source_mode]
    sources[mode] = str(config.get("source") or "")
    clean = {
        "version": 2,
        "mode": mode,
        "source": sources[mode],
        "sources": {source_mode: sources[source_mode] for source_mode in MODES},
        "fit": config["fit"],
        "background": normalize_background(config.get("background")),
        "power_save": as_bool(config.get("power_save", True), True),
        "pause_when_occluded": as_bool(config.get("pause_when_occluded", True), True),
        "pause_when_locked": as_bool(config.get("pause_when_locked", True), True),
        "pause_when_dpms_off": as_bool(config.get("pause_when_dpms_off", True), True),
        "battery_power_boost": as_bool(config.get("battery_power_boost", True), True),
        "pause_cover_threshold": clamp_cover_threshold(
            config.get("pause_cover_threshold", DEFAULT_CONFIG["pause_cover_threshold"])
        ),
        "playback_scale": clamp_playback_scale(
            config.get("playback_scale", DEFAULT_CONFIG["playback_scale"])
        ),
        "max_video_height": clamp_max_video_height(config.get("max_video_height", 0)),
        "video_backend": (
            config.get("video_backend")
            if str(config.get("video_backend", "mpv")).lower() in {"mpv", "webkit"}
            else "mpv"
        ),
    }
    CONFIG_DIR.mkdir(mode=0o700, parents=True, exist_ok=True)
    CONFIG_DIR.chmod(0o700)
    with exclusive_lock(CONFIG_LOCK_FILE):
        write_text_atomic(
            CONFIG_FILE,
            json.dumps(clean, ensure_ascii=False, indent=2) + "\n",
        )


def active_config_line(path, expected):
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except (FileNotFoundError, OSError):
        return False
    return any(line.strip() == expected for line in lines)


def autostart_enabled():
    return active_config_line(
        HYPR_INCLUDE, HYPR_AUTOSTART_LINE
    ) or active_config_line(HYPR_MAIN, HYPR_AUTOSTART_LINE)


def set_autostart(enabled):
    HYPR_INCLUDE_DIR.mkdir(parents=True, exist_ok=True)
    include_lines = [
        "# Villode Desktop",
        HYPR_DESKTOP_LINE,
        "",
    ]
    if enabled:
        include_lines.append(HYPR_AUTOSTART_LINE)
    include_lines.append(HYPR_BIND_LINE)
    write_text_atomic(HYPR_INCLUDE, "\n".join(include_lines) + "\n")

    HYPR_DIR.mkdir(parents=True, exist_ok=True)
    try:
        main_lines = HYPR_MAIN.read_text(encoding="utf-8").splitlines()
    except (FileNotFoundError, OSError):
        main_lines = []
    managed_direct_lines = {
        HYPR_DESKTOP_LINE,
        HYPR_AUTOSTART_LINE,
        HYPR_BIND_LINE,
    }
    clean_lines = [
        line
        for line in main_lines
        if line.strip() not in managed_direct_lines
    ]
    if not any(line.strip() == HYPR_SOURCE_LINE for line in clean_lines):
        if clean_lines and clean_lines[-1].strip():
            clean_lines.append("")
        clean_lines.extend(("# Villode Desktop", HYPR_SOURCE_LINE))
    write_text_atomic(HYPR_MAIN, "\n".join(clean_lines).rstrip() + "\n")

    try:
        subprocess.run(
            ["hyprctl", "reload"],
            check=False,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=2,
        )
    except (OSError, subprocess.TimeoutExpired):
        pass


def is_web_uri(source):
    return source.startswith(("http://", "https://"))


def local_source_path(source):
    if source.startswith("file://"):
        return Path(unquote(urlparse(source).path))
    if is_web_uri(source):
        return None
    return Path(source).expanduser().resolve()


def normalize_uri(source):
    if source.startswith(("http://", "https://", "file://")):
        return source
    return Path(source).expanduser().resolve().as_uri()


def is_trusted_home_uri(uri):
    if not isinstance(uri, str) or not uri.startswith("file://"):
        return False
    try:
        path = Path(unquote(urlparse(uri).path)).resolve()
        return path == DEFAULT_HTML.resolve()
    except (OSError, ValueError):
        return False


def gstreamer_has_qtdemux():
    """MP4/MOV playback needs qtdemux from gst-plugins-good."""
    try:
        import gi

        gi.require_version("Gst", "1.0")
        from gi.repository import Gst

        if not Gst.is_initialized():
            Gst.init(None)
        return Gst.ElementFactory.find("qtdemux") is not None
    except Exception:
        return False


def validate_config(config):
    mode = config.get("mode")
    source = str(config.get("source") or "").strip()
    if mode not in MODES:
        return "不支持的桌面模式。"
    if not source:
        return "请选择或输入内容来源。"
    if mode == "static" and is_web_uri(source):
        return "静态图片模式请选择本地图片。"
    path = local_source_path(source)
    if path is not None and not path.is_file():
        return f"找不到文件：{path}"
    if path is not None:
        suffix = path.suffix.casefold()
        if mode == "static" and suffix not in IMAGE_SUFFIXES:
            return "静态图片模式只支持 PNG、JPG、WEBP、BMP 或 GIF 文件。"
        if mode == "video" and suffix not in VIDEO_SUFFIXES:
            return "循环视频模式只支持 MP4、WEBM、MKV、MOV、M4V 或 AVI 文件。"
        if mode == "html" and suffix not in HTML_SUFFIXES:
            return "本地 HTML 模式只支持 HTML 或 HTM 文件。"
    if mode == "video" and not gstreamer_has_qtdemux():
        return (
            "缺少 GStreamer MP4 解复用插件（qtdemux）。\n"
            "Arch: sudo pacman -S gst-plugins-good gst-plugins-base\n"
            "Debian/Ubuntu: sudo apt install gstreamer1.0-plugins-good"
        )
    return None


def apply_static_wallpaper(source):
    path = local_source_path(str(source))
    if path is None:
        return False, "Caelestia 静态壁纸必须是本地文件。"
    try:
        result = subprocess.run(
            ["caelestia", "wallpaper", "-f", str(path)],
            check=False,
            stdin=subprocess.DEVNULL,
            capture_output=True,
            text=True,
            timeout=20,
        )
    except (OSError, subprocess.TimeoutExpired) as error:
        return False, f"无法调用 Caelestia 设置壁纸：{error}"
    if result.returncode != 0:
        message = (result.stderr or result.stdout).strip()
        return False, message or f"Caelestia 退出码：{result.returncode}"
    return True, ""


def _spawn_desktop(args=None):
    command = [str(Path(__file__).resolve()), "--run"]
    if args is not None:
        if getattr(args, "url", None):
            command.extend(("--url", args.url))
        if getattr(args, "escape_quits", False):
            command.append("--escape-quits")
    return subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
        close_fds=True,
    )


def wait_for_registration(process, timeout=2.0):
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        pid = read_pid()
        if process_alive(pid):
            return pid
        if process.poll() is not None:
            return None
        time.sleep(0.025)
    return read_pid() if process_alive(read_pid()) else None


def ensure_desktop_started(args=None):
    with exclusive_lock(OPERATION_LOCK_FILE):
        pid = read_pid()
        if process_alive(pid):
            return pid
        PID_FILE.unlink(missing_ok=True)
        process = _spawn_desktop(args)
        return wait_for_registration(process)


def restart_desktop(args=None, config=None):
    effective = config or load_config()
    if args is not None and getattr(args, "url", None):
        effective = {
            **effective,
            "mode": "html",
            "source": args.url,
        }
    with exclusive_lock(OPERATION_LOCK_FILE):
        _stop_running()
        if effective["mode"] == "static":
            return apply_static_wallpaper(effective["source"])
        process = _spawn_desktop(args)
        pid = wait_for_registration(process)
        if pid is None:
            return False, "Villode Desktop 进程未能启动。"
        return True, ""


def apply_saved_config(config, start_non_static):
    if config["mode"] == "static":
        success, message = apply_static_wallpaper(config["source"])
        if success:
            stop_running()
        return success, message
    if start_non_static:
        return restart_desktop(config=config)
    return True, ""


def toggle_desktop(args=None):
    config = load_config()
    with exclusive_lock(OPERATION_LOCK_FILE):
        if process_alive(read_pid()):
            _stop_running()
            return True, ""
        if config["mode"] == "static":
            return apply_static_wallpaper(config["source"])
        process = _spawn_desktop(args)
        if wait_for_registration(process) is None:
            return False, "Villode Desktop 进程未能启动。"
        return True, ""


def set_if_supported(obj, name, value):
    try:
        obj.set_property(name, value)
    except Exception:
        pass


def launch_command(command):
    subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def resolve_mpvpaper():
    """Prefer bundled binary, then PATH."""
    if BUNDLED_MPVPAPER.is_file() and os.access(BUNDLED_MPVPAPER, os.X_OK):
        return str(BUNDLED_MPVPAPER)
    for name in ("mpvpaper",):
        from shutil import which
        found = which(name)
        if found:
            return found
    return None


def hyprland_monitor_names():
    try:
        data = hyprctl_json("monitors") or []
    except Exception:
        data = []
    names = []
    for mon in data:
        name = (mon or {}).get("name")
        if name:
            names.append(str(name))
    return names


def mpv_fit_options(fit):
    """Map cover/contain/stretch to mpv video options (full-bleed layer)."""
    fit = (fit or "cover").lower()
    if fit == "contain":
        return "keepaspect=yes panscan=0.0 video-unscaled=no"
    if fit == "stretch":
        return "keepaspect=no panscan=0.0 video-unscaled=no"
    # cover (default): fill and crop like object-fit:cover
    return "keepaspect=yes panscan=1.0 video-unscaled=no"


def mpv_ipc_command(command, timeout=1.0):
    """Send a JSON IPC command to the wallpaper mpv instance."""
    sock_path = MPV_IPC_SOCK
    if not sock_path.exists():
        return None
    import socket

    payload = json.dumps({"command": command}, ensure_ascii=False) + "\n"
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        sock.connect(str(sock_path))
        sock.sendall(payload.encode("utf-8"))
        chunks = []
        while True:
            try:
                data = sock.recv(4096)
            except socket.timeout:
                break
            if not data:
                break
            chunks.append(data)
            if b"\n" in data:
                break
        sock.close()
        raw = b"".join(chunks).decode("utf-8", errors="replace").strip()
        if not raw:
            return None
        return json.loads(raw.splitlines()[0])
    except (OSError, ValueError, json.JSONDecodeError):
        return None


def mpv_set_paused(paused):
    """Pause/resume native video wallpaper (Wallpaper Engine style)."""
    return mpv_ipc_command(["set_property", "pause", bool(paused)])


def build_mpvpaper_command(config):
    """Build mpvpaper argv for WE-style looping muted hard-decoded video."""
    binary = resolve_mpvpaper()
    if not binary:
        return None, "未找到 mpvpaper。请运行 install.sh 安装，或将 mpvpaper 放入 PATH。"
    source = local_source_path(config["source"])
    if source is None or not source.is_file():
        return None, f"视频文件不存在：{config.get('source')}"
    monitors = hyprland_monitor_names()
    output = monitors[0] if monitors else "ALL"
    # Prefer ALL so multi-monitor setups get wallpaper; mpvpaper accepts ALL.
    if len(monitors) != 1:
        output = "ALL"
    MPV_IPC_SOCK.parent.mkdir(parents=True, exist_ok=True)
    try:
        MPV_IPC_SOCK.unlink()
    except FileNotFoundError:
        pass
    except OSError:
        pass
    fit_opts = mpv_fit_options(config.get("fit"))
    # Wallpaper Engine video profile:
    # - muted infinite loop
    # - hardware decode (vaapi/nvdec)
    # - libmpv VO (required by mpvpaper)
    # - no OSD / idle quit
    # mpvpaper -p -a max: auto-pause when hidden / fullscreen / maximized
    mpv_opts = " ".join(
        [
            "no-audio",
            "loop-file=inf",
            "hwdec=auto",
            "vo=libmpv",
            "gpu-api=auto",
            "osd-level=0",
            "really-quiet",
            f"input-ipc-server={MPV_IPC_SOCK}",
            fit_opts,
        ]
    )
    cmd = [
        binary,
        "-p",  # auto-pause when wallpaper layer is occluded by compositor
        "-a",
        "max",  # also when any window is fullscreen/maximized
        "-l",
        "background",
        "-o",
        mpv_opts,
        output,
        str(source),
    ]
    return cmd, ""


def run_video_wallpaper(config, args):
    """Run native mpvpaper video wallpaper (not WebKit).

    Process model matches Wallpaper Engine video wallpapers:
    lightweight native player on a background layer-shell surface with
    hardware decode and auto-pause when occluded.
    """
    instance_lock = acquire_instance_lock()
    if instance_lock is None:
        return 0

    cmd, err = build_mpvpaper_command(config)
    if cmd is None:
        release_instance_lock(instance_lock)
        print(err, file=sys.stderr)
        return 1

    write_pid(os.getpid())
    log_path = Path.home() / ".cache" / "villode-desktop-mpvpaper.log"
    log_path.parent.mkdir(parents=True, exist_ok=True)
    log_fh = open(log_path, "ab", buffering=0)

    try:
        proc = subprocess.Popen(
            cmd,
            stdin=subprocess.DEVNULL,
            stdout=log_fh,
            stderr=subprocess.STDOUT,
            start_new_session=True,
            close_fds=True,
        )
    except OSError as exc:
        log_fh.close()
        release_instance_lock(instance_lock)
        PID_FILE.unlink(missing_ok=True)
        print(f"无法启动 mpvpaper：{exc}", file=sys.stderr)
        return 1

    child = proc
    _paused = False
    _pause_reason = "ok"
    stop = {"flag": False}

    def request_stop(signum=None, frame=None):
        stop["flag"] = True

    signal.signal(signal.SIGTERM, request_stop)
    signal.signal(signal.SIGINT, request_stop)

    power_on = as_bool(config.get("power_save", True), True)
    # Wait for IPC sock a moment so first pause/resume works.
    deadline = time.monotonic() + 3.0
    while time.monotonic() < deadline and not MPV_IPC_SOCK.exists() and not stop["flag"]:
        if child.poll() is not None:
            break
        time.sleep(0.05)

    try:
        while not stop["flag"]:
            if child.poll() is not None:
                # mpvpaper exited
                break
            if power_on:
                pause, reason = hyprland_should_pause_media(config)
                if pause != _paused or reason != _pause_reason:
                    _paused = pause
                    _pause_reason = reason
                    mpv_set_paused(pause)
            # 1.5s poll — same cadence as previous WebKit power monitor
            for _ in range(15):
                if stop["flag"]:
                    break
                if child.poll() is not None:
                    break
                time.sleep(0.1)
    finally:
        if child.poll() is None:
            try:
                # Ask mpv to quit cleanly via IPC first
                mpv_ipc_command(["quit"])
            except Exception:
                pass
            try:
                child.terminate()
            except ProcessLookupError:
                pass
            try:
                child.wait(timeout=2.0)
            except Exception:
                try:
                    child.kill()
                except ProcessLookupError:
                    pass
        log_fh.close()
        try:
            MPV_IPC_SOCK.unlink()
        except OSError:
            pass
        if read_pid() == os.getpid():
            PID_FILE.unlink(missing_ok=True)
        release_instance_lock(instance_lock)
    return 0 if not stop["flag"] or child.returncode in (0, None, -signal.SIGTERM) else (child.returncode or 1)


def build_video_document(config):
    """Full-bleed looping video. Always paints 100% of the layer (cover/contain/fill).

    Thermal savings come from lower-res source files and host pause injection —
    not from shrinking the painted surface (which leaves black borders).
    """
    source = html.escape(normalize_uri(config["source"]), quote=True)
    fit = "fill" if config["fit"] == "stretch" else config["fit"]
    background = normalize_background(config.get("background"))
    return f"""<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    html, body {{ width: 100%; height: 100%; margin: 0; overflow: hidden; background: {background}; }}
    video {{
      position: fixed; inset: 0;
      width: 100%; height: 100%;
      display: block; object-fit: {fit}; background: {background};
    }}
    #error {{ display: none; position: fixed; inset: 0; place-items: center; color: #dce7f8;
      background: {background}; font: 16px system-ui, sans-serif; z-index: 2; }}
  </style>
</head>
<body>
  <video id="wallpaper" src="{source}" autoplay muted loop playsinline preload="auto"
    disablepictureinpicture disableremoteplayback></video>
  <div id="error">无法播放当前视频。若是 MP4，请确认已安装 gst-plugins-good（提供 qtdemux）；也可打开 Villode Desktop 设置更换文件。</div>
  <script>
    const video = document.getElementById("wallpaper");
    const error = document.getElementById("error");
    video.muted = true;
    video.playsInline = true;
    try {{ video.playbackRate = 1.0; }} catch (e) {{}}
    function tryPlay() {{
      if (window.__villodeHostPaused || window.__villodeIsPaused) return;
      video.muted = true;
      const p = video.play();
      if (p && typeof p.catch === "function") p.catch(() => {{}});
    }}
    tryPlay();
    video.addEventListener("loadeddata", tryPlay);
    video.addEventListener("canplay", tryPlay);
    video.addEventListener("error", () => {{ error.style.display = "grid"; }});
    // Do not pause solely on document.hidden — layer-shell often lies.
    document.addEventListener("visibilitychange", () => {{
      if (!document.hidden && !window.__villodeHostPaused) tryPlay();
    }});
    setInterval(function () {{
      if (!window.__villodeHostPaused && video.paused && !video.ended) tryPlay();
    }}, 2500);
    const _set = window.__villodeSetPaused;
    window.__villodeSetPaused = function (next) {{
      window.__villodeIsPaused = !!next;
      if (typeof _set === "function") _set(next);
      if (next) video.pause();
      else tryPlay();
    }};
  </script>
</body>
</html>"""



def run_configurator():
    import gi

    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk

    config = load_config()
    dialog = Gtk.Dialog(title="Villode Desktop 设置")
    dialog.set_default_size(680, 480)
    dialog.set_resizable(False)
    dialog.add_button("取消", Gtk.ResponseType.CANCEL)
    dialog.add_button("保存并应用", Gtk.ResponseType.APPLY)
    dialog.set_default_response(Gtk.ResponseType.APPLY)

    content = dialog.get_content_area()
    content.set_border_width(20)
    content.set_spacing(14)

    title = Gtk.Label()
    title.set_markup("<span size='x-large' weight='bold'>桌面背景</span>")
    title.set_xalign(0)
    content.pack_start(title, False, False, 0)

    subtitle = Gtk.Label(
        label="静态图片交给 Caelestia 统一显示；视频使用硬件加速的 WebKit/GStreamer；HTML 可选择本地文件或输入网址。"
    )
    subtitle.set_xalign(0)
    subtitle.set_line_wrap(True)
    content.pack_start(subtitle, False, False, 0)

    grid = Gtk.Grid(column_spacing=12, row_spacing=12)
    content.pack_start(grid, True, True, 0)

    def field_label(text, row):
        label = Gtk.Label(label=text)
        label.set_xalign(1)
        grid.attach(label, 0, row, 1, 1)

    field_label("类型", 0)
    mode_combo = Gtk.ComboBoxText()
    mode_combo.append("static", "静态图片")
    mode_combo.append("video", "循环视频")
    mode_combo.append("html", "自定义 HTML / 网址")
    mode_combo.set_active_id(config["mode"])
    grid.attach(mode_combo, 1, 0, 2, 1)

    field_label("来源", 1)
    source_entry = Gtk.Entry()
    source_entry.set_hexpand(True)
    source_entry.set_text(config["source"])
    grid.attach(source_entry, 1, 1, 1, 1)
    browse_button = Gtk.Button(label="浏览…")
    grid.attach(browse_button, 2, 1, 1, 1)

    field_label("填充方式", 2)
    fit_combo = Gtk.ComboBoxText()
    fit_combo.append("cover", "覆盖屏幕（可能裁剪）")
    fit_combo.append("contain", "完整显示（可能留边）")
    fit_combo.append("stretch", "拉伸填满")
    fit_combo.set_active_id(config["fit"])
    grid.attach(fit_combo, 1, 2, 2, 1)

    field_label("背景色", 3)
    background_entry = Gtk.Entry()
    background_entry.set_text(config["background"])
    background_entry.set_max_length(9)
    grid.attach(background_entry, 1, 3, 2, 1)

    field_label("自动启动", 4)
    autostart_check = Gtk.CheckButton(label="登录 Hyprland 后自动运行")
    autostart_check.set_active(autostart_enabled())
    grid.attach(autostart_check, 1, 4, 2, 1)

    field_label("省电", 5)
    power_check = Gtk.CheckButton(
        label="窗口遮挡/锁屏/关屏时自动暂停动态壁纸（降温）"
    )
    power_check.set_active(as_bool(config.get("power_save", True), True))
    grid.attach(power_check, 1, 5, 2, 1)

    field_label("电池增强", 6)
    batt_check = Gtk.CheckButton(label="使用电池时更激进省电（更低缩放、更早暂停）")
    batt_check.set_active(as_bool(config.get("battery_power_boost", True), True))
    grid.attach(batt_check, 1, 6, 2, 1)

    field_label("清晰度档", 7)
    scale_combo = Gtk.ComboBoxText()
    # Kept as a preference marker (battery boost still reads playback_scale).
    # Display is always full-screen; lower values only bias battery aggressiveness.
    for value, label in (
        ("1.0", "高清（全屏）"),
        ("0.85", "均衡（全屏）"),
        ("0.75", "推荐省电（全屏）"),
        ("0.6", "最省电（全屏）"),
    ):
        scale_combo.append(value, label)
    current_scale = f"{clamp_playback_scale(config.get('playback_scale', 0.75)):.2f}".rstrip("0").rstrip(".")
    if current_scale not in {"1", "1.0", "0.85", "0.75", "0.6"}:
        options = [1.0, 0.85, 0.75, 0.6]
        nearest = min(options, key=lambda x: abs(x - float(current_scale or 0.75)))
        current_scale = f"{nearest:g}"
    if current_scale == "1":
        current_scale = "1.0"
    scale_combo.set_active_id(
        {"1": "1.0", "1.0": "1.0", "0.85": "0.85", "0.75": "0.75", "0.6": "0.6"}.get(
            current_scale, "0.75"
        )
    )
    grid.attach(scale_combo, 1, 7, 2, 1)

    hint = Gtk.Label()
    hint.set_xalign(0)
    hint.set_line_wrap(True)
    grid.attach(hint, 1, 8, 2, 1)

    last_mode = mode_combo.get_active_id()
    mode_sources = dict(config["sources"])
    mode_sources[last_mode] = source_entry.get_text()

    def update_mode_ui(*_args):
        nonlocal last_mode
        mode = mode_combo.get_active_id()
        if mode != last_mode:
            mode_sources[last_mode] = source_entry.get_text()
            source_entry.set_text(mode_sources.get(mode, ""))
            last_mode = mode
        fit_combo.set_sensitive(mode == "video")
        background_entry.set_sensitive(mode == "video")
        if mode == "static":
            source_entry.set_placeholder_text("选择 PNG、JPG、WEBP 等图片")
            hint.set_text("静态模式由 Caelestia 显示，不会额外创建桌面图层。")
        elif mode == "video":
            source_entry.set_placeholder_text("选择 MP4、WEBM、MKV 等视频")
            hint.set_text("视频由 mpv/mpvpaper 原生硬解全屏循环（Wallpaper Engine 同款路径，非浏览器）。推荐 720p–1080p H.264；遮挡/全屏/锁屏时自动暂停。")
        else:
            source_entry.set_placeholder_text("选择 .html 文件，或输入 https:// 网址")
            hint.set_text("HTML/网页在 WebKit 中运行；含视频时同样会因全屏/锁屏自动暂停。")

    def browse_source(_button):
        mode = mode_combo.get_active_id()
        chooser = Gtk.FileChooserDialog(
            title="选择桌面内容",
            parent=dialog,
            action=Gtk.FileChooserAction.OPEN,
        )
        chooser.add_buttons(
            "取消",
            Gtk.ResponseType.CANCEL,
            "选择",
            Gtk.ResponseType.OK,
        )
        media_filter = Gtk.FileFilter()
        if mode == "static":
            media_filter.set_name("图片")
            patterns = ("*.png", "*.jpg", "*.jpeg", "*.webp", "*.bmp", "*.gif")
        elif mode == "video":
            media_filter.set_name("视频")
            patterns = ("*.mp4", "*.webm", "*.mkv", "*.mov", "*.m4v", "*.avi")
        else:
            media_filter.set_name("HTML")
            patterns = ("*.html", "*.htm")
        for pattern in patterns:
            media_filter.add_pattern(pattern)
            media_filter.add_pattern(pattern.upper())
        chooser.add_filter(media_filter)
        current = local_source_path(source_entry.get_text().strip())
        if current is not None:
            if current.is_file():
                chooser.set_filename(str(current))
            elif current.parent.is_dir():
                chooser.set_current_folder(str(current.parent))
        if chooser.run() == Gtk.ResponseType.OK:
            source_entry.set_text(chooser.get_filename())
        chooser.destroy()

    mode_combo.connect("changed", update_mode_ui)
    browse_button.connect("clicked", browse_source)
    update_mode_ui()
    dialog.show_all()

    selected = None
    while True:
        response = dialog.run()
        if response != Gtk.ResponseType.APPLY:
            break
        candidate = {
            "version": 2,
            "mode": mode_combo.get_active_id(),
            "source": source_entry.get_text().strip(),
            "sources": {
                **mode_sources,
                mode_combo.get_active_id(): source_entry.get_text().strip(),
            },
            "fit": fit_combo.get_active_id() or "cover",
            "background": normalize_background(background_entry.get_text()),
            "power_save": power_check.get_active(),
            "pause_when_occluded": power_check.get_active(),
            "pause_when_locked": power_check.get_active(),
            "pause_when_dpms_off": power_check.get_active(),
            "battery_power_boost": batt_check.get_active(),
            "pause_cover_threshold": clamp_cover_threshold(
                config.get("pause_cover_threshold", DEFAULT_CONFIG["pause_cover_threshold"])
            ),
            "playback_scale": clamp_playback_scale(scale_combo.get_active_id() or 0.75),
            "max_video_height": clamp_max_video_height(config.get("max_video_height", 0)),
            "video_backend": "mpv",
        }
        error = validate_config(candidate)
        if error:
            message = Gtk.MessageDialog(
                transient_for=dialog,
                modal=True,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.CLOSE,
                text="无法保存设置",
            )
            message.format_secondary_text(error)
            message.run()
            message.destroy()
            continue
        selected = candidate
        break

    dialog.destroy()
    if selected is not None:
        save_config(selected)
        set_autostart(autostart_check.get_active())
        success, message = apply_saved_config(selected, True)
        if not success:
            print(f"应用桌面设置失败：{message}", file=sys.stderr)
            return 1
    return 0


def run_desktop(args):
    config = load_config()
    if args.url:
        config.update({"mode": "html", "source": args.url})
    if config["mode"] == "static":
        success, message = apply_static_wallpaper(config["source"])
        if not success:
            print(message, file=sys.stderr)
            return 1
        return 0

    # Wallpaper Engine-style native video (mpvpaper + VAAPI/NVDEC).
    # HTML still uses WebKit; only pure video leaves the browser path.
    if config["mode"] == "video" and str(config.get("video_backend", "mpv")).lower() != "webkit":
        return run_video_wallpaper(config, args)

    instance_lock = acquire_instance_lock()
    if instance_lock is None:
        return 0

    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    gi.require_version("GtkLayerShell", "0.1")
    gi.require_version("WebKit2", "4.1")

    from gi.repository import Gdk, Gio, GLib, Gtk, GtkLayerShell, WebKit2

    write_pid(os.getpid())

    def error_widget(message):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)
        label = Gtk.Label()
        label.set_markup(
            "<span size='x-large' weight='bold'>Villode Desktop</span>\n\n"
            + html.escape(message)
            + "\n\n运行 villode-desktop --configure 更换内容。"
        )
        label.set_justify(Gtk.Justification.CENTER)
        box.pack_start(label, False, False, 0)
        return box

    class DesktopApp(Gtk.Application):
        def __init__(self):
            super().__init__(application_id=APP_ID, flags=Gio.ApplicationFlags.FLAGS_NONE)
            self.window = None
            self.webview = None
            self.content = None
            self._paused = False
            self._pause_reason = "ok"
            self._power_source = None

        def make_webview(self, local_file_access=False, trusted_actions=False):
            manager = WebKit2.UserContentManager()
            try:
                shell_config = json.loads(CAELESTIA_CONFIG_FILE.read_text())
                weather_location = str(
                    shell_config.get("services", {}).get("weatherLocation", "")
                ).strip()
            except (FileNotFoundError, OSError, ValueError, TypeError):
                weather_location = ""
            manager.add_script(
                WebKit2.UserScript.new(
                    "window.__VILLODE_WEATHER_LOCATION__ = "
                    + json.dumps(weather_location, ensure_ascii=False)
                    + ";",
                    WebKit2.UserContentInjectedFrames.TOP_FRAME,
                    WebKit2.UserScriptInjectionTime.START,
                    None,
                    None,
                )
            )
            # Pause/resume media from host (occlusion / lock / DPMS)
            manager.add_script(
                WebKit2.UserScript.new(
                    power_user_script(),
                    WebKit2.UserContentInjectedFrames.TOP_FRAME,
                    WebKit2.UserScriptInjectionTime.START,
                    None,
                    None,
                )
            )
            webview = WebKit2.WebView.new_with_user_content_manager(manager)
            self.trusted_actions = bool(trusted_actions)
            self.remote_html = config["mode"] == "html" and is_web_uri(config["source"])
            settings = webview.get_settings()
            set_if_supported(settings, "enable-developer-extras", False)
            # Wallpaper does not need smooth scroll / page cache chrome.
            set_if_supported(settings, "enable-smooth-scrolling", False)
            set_if_supported(settings, "enable-page-cache", False)
            set_if_supported(settings, "enable-dns-prefetching", False)
            set_if_supported(settings, "enable-html5-database", False)
            set_if_supported(settings, "enable-html5-local-storage", False)
            set_if_supported(settings, "enable-offline-web-application-cache", False)
            set_if_supported(settings, "enable-hyperlink-auditing", False)
            set_if_supported(settings, "enable-media-stream", False)
            set_if_supported(settings, "enable-webrtc", False)
            set_if_supported(
                settings, "allow-file-access-from-file-urls", bool(local_file_access)
            )
            set_if_supported(settings, "allow-universal-access-from-file-urls", False)
            set_if_supported(settings, "javascript-can-access-clipboard", False)
            set_if_supported(settings, "allow-modal-dialogs", False)
            set_if_supported(settings, "media-playback-requires-user-gesture", False)
            try:
                # Prefer GPU decode/composite when available (cooler than software).
                settings.set_hardware_acceleration_policy(WebKit2.HardwareAccelerationPolicy.ALWAYS)
            except Exception:
                pass
            webview.connect("decide-policy", self.on_decide_policy)
            webview.connect("permission-request", self.on_permission_request)
            webview.connect("create", lambda *_args: None)
            webview.connect("context-menu", lambda *_args: True)
            return webview

        def source_is_trusted_home(self):
            if config["mode"] != "html" or is_web_uri(config["source"]):
                return False
            path = local_source_path(config["source"])
            if path is None:
                return False
            try:
                return path.resolve() == DEFAULT_HTML.resolve()
            except OSError:
                return False

        def on_permission_request(self, _webview, request):
            request.deny()
            return True

        def build_content(self):
            error = validate_config(config)
            if error:
                return error_widget(error)
            try:
                if config["mode"] == "video":
                    webview = self.make_webview(local_file_access=True)
                    self.webview = webview
                    source_path = local_source_path(config["source"])
                    base_uri = None
                    if source_path is not None:
                        base_uri = source_path.parent.as_uri() + "/"
                    webview.load_html(build_video_document(config), base_uri)
                else:
                    local_html = not is_web_uri(config["source"])
                    webview = self.make_webview(
                        local_file_access=local_html,
                        trusted_actions=self.source_is_trusted_home(),
                    )
                    self.webview = webview
                    webview.load_uri(normalize_uri(config["source"]))
                return webview
            except Exception as exc:
                return error_widget(str(exc))

        def do_activate(self):
            if self.window:
                self.window.present()
                return

            window = Gtk.ApplicationWindow(application=self)
            window.set_title(f"{TITLE} — {config['mode']}")
            window.set_name("villode-desktop-window")
            window.set_decorated(False)
            window.set_resizable(True)
            window.set_skip_taskbar_hint(True)
            window.set_skip_pager_hint(True)
            window.set_accept_focus(True)
            window.set_keep_below(True)
            window.set_type_hint(Gdk.WindowTypeHint.DESKTOP)

            GtkLayerShell.init_for_window(window)
            GtkLayerShell.set_namespace(window, "villode-desktop")
            GtkLayerShell.set_layer(window, GtkLayerShell.Layer.BACKGROUND)
            GtkLayerShell.set_keyboard_mode(window, GtkLayerShell.KeyboardMode.ON_DEMAND)
            for edge in (
                GtkLayerShell.Edge.TOP,
                GtkLayerShell.Edge.RIGHT,
                GtkLayerShell.Edge.BOTTOM,
                GtkLayerShell.Edge.LEFT,
            ):
                GtkLayerShell.set_anchor(window, edge, True)
                GtkLayerShell.set_margin(window, edge, 0)
            GtkLayerShell.set_exclusive_zone(window, -1)

            self.content = self.build_content()
            window.add(self.content)
            window.connect("key-press-event", self.on_key_press)
            window.connect("destroy", lambda *_: self.quit())
            window.show_all()
            self.window = window
            self.apply_playback_scale()
            self.start_power_monitor()

        def apply_playback_scale(self):
            """Keep wallpaper full-bleed.

            Do NOT apply WebKit zoom / CSS zoom — that shrinks the painted
            surface and leaves borders. Cooler playback uses lower-res sources
            (e.g. 720p proxy) and host-side pause, not a smaller window.
            """
            if self.webview is None:
                return
            try:
                self.webview.connect("load-changed", self._on_load_apply_scale)
            except Exception:
                pass

        def _on_load_apply_scale(self, webview, load_event):
            try:
                from gi.repository import WebKit2 as WK
            except Exception:
                return
            if int(load_event) != int(WK.LoadEvent.FINISHED):
                return
            # Always full size
            try:
                webview.set_zoom_level(1.0)
            except Exception:
                pass
            try:
                webview.run_javascript(
                    "try{document.documentElement.style.zoom='';"
                    "document.body&&(document.body.style.zoom='');}catch(e){}",
                    None, None, None,
                )
            except Exception:
                pass

        def start_power_monitor(self):
            # Always clear any sticky JS pause shortly after load (layer-shell
            # WebViews sometimes start with document.hidden=true).
            GLib.timeout_add(800, lambda: (self.apply_media_paused(False) or False))
            if not as_bool(config.get("power_save", True), True):
                return
            # Poll Hyprland every 1.5s — cheap vs continuous 1080p decode
            self._power_source = GLib.timeout_add(1500, self.poll_power_state)
            # Immediate first check after short delay (clients may not exist yet)
            GLib.timeout_add(400, self.poll_power_state)

        def poll_power_state(self):
            pause, reason = hyprland_should_pause_media(config)
            if pause != self._paused or reason != self._pause_reason:
                self._paused = pause
                self._pause_reason = reason
                self.apply_media_paused(pause)
            return True  # keep timer

        def apply_media_paused(self, paused):
            if self.webview is None:
                return
            flag = "true" if paused else "false"
            js = (
                "try{window.__villodeHostPaused=%s;"
                "if(window.__villodeSetPaused)window.__villodeSetPaused(%s);"
                "window.__villodeIsPaused=%s;}catch(e){}"
                % (flag, flag, flag)
            )
            try:
                self.webview.run_javascript(js, None, None, None)
            except Exception:
                pass
            # When paused long-term, also drop WebKit process priority via freeze css already
            try:
                if paused:
                    self.window.set_opacity(0.999)  # no-op visual, keeps map
                else:
                    self.window.set_opacity(1.0)
            except Exception:
                pass

        def on_key_press(self, _window, event):
            key = Gdk.keyval_name(event.keyval) or ""
            ctrl = bool(event.state & Gdk.ModifierType.CONTROL_MASK)
            if key == "F5" or (ctrl and key.lower() == "r"):
                if self.webview:
                    self.webview.reload()
                elif self.content:
                    self.content.queue_draw()
                return True
            if ctrl and key == ",":
                launch_command(ACTION_COMMANDS["settings"])
                return True
            if (ctrl and key.lower() == "q") or (args.escape_quits and key == "Escape"):
                self.quit()
                return True
            return False

        def on_decide_policy(self, _webview, decision, decision_type):
            if decision_type == WebKit2.PolicyDecisionType.NEW_WINDOW_ACTION:
                decision.ignore()
                return True
            if decision_type != WebKit2.PolicyDecisionType.NAVIGATION_ACTION:
                return False
            action = decision.get_navigation_action()
            request = action.get_request() if action else None
            target_uri = request.get_uri() if request else ""
            parsed = urlparse(target_uri)
            scheme = parsed.scheme.casefold()
            if self.remote_html and scheme not in {"http", "https", "about"}:
                decision.ignore()
                return True
            if not target_uri.startswith("villode-action://"):
                return False

            decision.ignore()
            user_gesture = bool(action and action.is_user_gesture())
            if not (
                self.trusted_actions
                and user_gesture
                and is_trusted_home_uri(_webview.get_uri())
            ):
                return True
            name = urlparse(target_uri).netloc or urlparse(target_uri).path.lstrip("/")
            if name == "reload":
                self.webview.reload()
            elif name == "quit":
                self.quit()
            elif name in ACTION_COMMANDS:
                launch_command(ACTION_COMMANDS[name])
            return True

    app = DesktopApp()

    def request_quit(*_args):
        app.quit()
        return False

    GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGTERM, request_quit)
    GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGINT, request_quit)

    try:
        return app.run([])
    finally:
        if read_pid() == os.getpid():
            PID_FILE.unlink(missing_ok=True)
        release_instance_lock(instance_lock)


def main():
    parser = argparse.ArgumentParser(description="Villode Hyprland desktop background manager")
    parser.add_argument("--run", action="store_true", help="run the desktop layer in this process")
    parser.add_argument("--daemon", action="store_true", help="start the configured desktop layer")
    parser.add_argument("--toggle", action="store_true", help="toggle the desktop layer")
    parser.add_argument("--reload", action="store_true", help="restart and reload the desktop layer")
    parser.add_argument("--quit", action="store_true", help="stop the desktop layer")
    parser.add_argument("--configure", "--settings", action="store_true", help="open graphical settings")
    parser.add_argument("--status", action="store_true", help="show the saved configuration and process state")
    autostart_group = parser.add_mutually_exclusive_group()
    autostart_group.add_argument(
        "--enable-autostart",
        action="store_true",
        help="start Villode Desktop automatically after Hyprland login",
    )
    autostart_group.add_argument(
        "--disable-autostart",
        action="store_true",
        help="disable automatic startup after Hyprland login",
    )
    autostart_group.add_argument(
        "--autostart-status",
        action="store_true",
        help="show whether Hyprland autostart is enabled",
    )
    parser.add_argument("--url", help="compatibility override: render this local HTML file or URL")
    source_group = parser.add_mutually_exclusive_group()
    source_group.add_argument("--set-static", metavar="PATH", help="select a static image")
    source_group.add_argument("--set-video", metavar="PATH", help="select a looping video")
    source_group.add_argument("--set-html", metavar="PATH_OR_URL", help="select custom HTML or a URL")
    parser.add_argument("--fit", choices=FITS, help="image/video fit mode")
    parser.add_argument("--background", metavar="#RRGGBB", help="background color")
    parser.add_argument("--escape-quits", action="store_true", help="let Escape close the desktop layer")
    parser.add_argument(
        "--playback-scale",
        type=float,
        metavar="0.5-1.0",
        help="WebKit render scale for video/HTML (lower = cooler)",
    )
    parser.add_argument(
        "--no-power-save",
        action="store_true",
        help="disable auto-pause when occluded/locked/DPMS off",
    )
    args = parser.parse_args()

    if args.configure:
        return run_configurator()
    if args.enable_autostart:
        set_autostart(True)
        config = load_config()
        if config["mode"] == "static":
            success, message = apply_saved_config(config, False)
        else:
            success = ensure_desktop_started(args) is not None
            message = "" if success else "Villode Desktop 进程未能启动。"
        if not success:
            print(message, file=sys.stderr)
            return 1
        print("已启用 Villode Desktop 登录后自动运行。")
        return 0
    if args.disable_autostart:
        set_autostart(False)
        print("已关闭 Villode Desktop 登录后自动运行。")
        return 0
    if args.autostart_status:
        print("enabled" if autostart_enabled() else "disabled")
        return 0
    if args.status:
        payload = load_config()
        payload["running"] = process_alive(read_pid())
        payload["pid"] = read_pid() if payload["running"] else None
        payload["autostart"] = autostart_enabled()
        print(json.dumps(payload, ensure_ascii=False, indent=2))
        return 0

    selected = None
    if args.set_static:
        selected = ("static", args.set_static)
    elif args.set_video:
        selected = ("video", args.set_video)
    elif args.set_html:
        selected = ("html", args.set_html)
    if selected or args.fit or args.background or args.playback_scale is not None or args.no_power_save:
        config = load_config()
        if selected:
            config["mode"], config["source"] = selected
        if args.fit:
            config["fit"] = args.fit
        if args.background:
            config["background"] = normalize_background(args.background)
        if args.playback_scale is not None:
            config["playback_scale"] = clamp_playback_scale(args.playback_scale)
        if args.no_power_save:
            config["power_save"] = False
        error = validate_config(config)
        if error:
            print(error, file=sys.stderr)
            return 2
        was_running = process_alive(read_pid())
        save_config(config)
        success, message = apply_saved_config(
            config, was_running or selected is not None
        )
        if not success:
            print(f"应用桌面设置失败：{message}", file=sys.stderr)
            return 1
        print(f"已设置 {config['mode']} 桌面：{config['source']}")
        return 0

    if args.quit:
        stop_running()
        return 0
    if args.reload:
        success, message = restart_desktop(args)
        if not success:
            print(message, file=sys.stderr)
            return 1
        return 0
    if args.toggle:
        success, message = toggle_desktop(args)
        if not success:
            print(message, file=sys.stderr)
            return 1
        return 0
    if args.daemon:
        config = load_config()
        if config["mode"] == "static":
            success, message = apply_saved_config(config, False)
        else:
            success = ensure_desktop_started(args) is not None
            message = "" if success else "Villode Desktop 进程未能启动。"
        if not success:
            print(message, file=sys.stderr)
            return 1
        return 0
    if args.run:
        return run_desktop(args)

    parser.print_help()
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
